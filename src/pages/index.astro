---
// CV Builder — Index page listing all available CVs
import CVLayout from '../layouts/CVLayout.astro';

const cvs = [
  { slug: 'mihaja', name: 'Andriamihaja RABARINJATOVO', title: 'Mécanicien Motoriste' },
];
---

<CVLayout title="CV Builder — Nexio">
  <div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-8">
    <div class="max-w-2xl w-full">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">CV Builder</h1>
      <p class="text-gray-600 mb-8">Généré depuis JSON → HTML/PDF. ATS-friendly.</p>

      <div class="space-y-3">
        {cvs.map((cv) => (
          <a href={`/${cv.slug}`} class="block bg-white p-5 rounded-xl shadow hover:shadow-md transition-shadow border border-gray-100">
            <p class="font-semibold text-gray-900">{cv.name}</p>
            <p class="text-sm text-gray-500">{cv.title}</p>
          </a>
        ))}
      </div>

      <div class="mt-8 text-xs text-gray-400">
        <p>Powered by Astro + Cloudflare Pages</p>
      </div>
    </div>
  </div>
</CVLayout>
