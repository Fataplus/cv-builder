---
// CV Builder — Index page
import CVLayout from '../layouts/CVLayout.astro';

const cvs = [
  { slug: 'mihaja', name: 'Andriamihaja RABARINJATOVO', title: 'Mécanicien Motoriste', theme: 'editorial' },
  { slug: 'fenohery', name: 'Fenohery FANOMEZANIRINA', title: 'Fullstack Dev & UX/UI Designer', theme: 'editorial' },
];
---

<CVLayout title="CV Builder — Nexio">
  <div class="page">
    <div class="container">
      <div class="hero">
        <span class="badge">ATS-Friendly</span>
        <h1>CV Builder</h1>
        <p>JSON → HTML → PDF. Chaque CV est généré depuis un fichier JSON, rendu en HTML sémantique optimisé pour les ATS, et exportable en PDF.</p>
      </div>

      <div class="links">
        <a href="/themes" class="link-card primary">
          <div>
            <p class="link-title">Catalogue de Thèmes</p>
            <p class="link-desc">6 thèmes: editorial, minimal, dark, swiss, classic, creative</p>
          </div>
          <span class="arrow">→</span>
        </a>
      </div>

      <h2 class="section-title">CVs</h2>
      <div class="cv-list">
        {cvs.map((cv) => (
          <a href={`/${cv.slug}`} class="link-card">
            <div>
              <p class="link-title">{cv.name}</p>
              <p class="link-desc">{cv.title}</p>
            </div>
            <span class="arrow">→</span>
          </a>
        ))}
      </div>

      <div class="footer">
        <p>Astro + Cloudflare Pages · <a href="https://github.com/Fataplus/cv-builder">GitHub</a></p>
      </div>
    </div>
  </div>
</CVLayout>

<style>
  .page { min-height: 100vh; background: #fafaf9; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
  .container { max-width: 560px; width: 100%; }
  .hero { margin-bottom: 32px; }
  .badge { display: inline-block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #1e3a5f; background: #e8edf3; padding: 4px 10px; border-radius: 99px; margin-bottom: 12px; }
  .hero h1 { font-size: 36px; font-weight: 800; color: #1c1917; margin: 0 0 8px; letter-spacing: -0.02em; }
  .hero p { color: #57534e; font-size: 15px; line-height: 1.5; margin: 0; }

  .links { margin-bottom: 32px; }
  .section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #78716c; margin: 0 0 12px; }
  .cv-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 40px; }

  .link-card {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    background: #fff; padding: 16px 20px; border-radius: 12px;
    border: 1px solid #e7e5e4; text-decoration: none; color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .link-card:hover { border-color: #d6d3d1; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .link-card.primary { border-color: #1e3a5f; border-width: 2px; }
  .link-title { font-size: 15px; font-weight: 600; color: #1c1917; margin: 0; }
  .link-desc { font-size: 13px; color: #78716c; margin: 2px 0 0; }
  .arrow { font-size: 18px; color: #a8a29e; }

  .footer { text-align: center; }
  .footer p { font-size: 12px; color: #a8a29e; }
  .footer a { color: #1e3a5f; }
</style>
