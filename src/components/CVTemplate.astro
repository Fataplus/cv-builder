---
// CV Template — Modern Editorial (ATS-friendly)
// Inspired by: resume-modern (A4 minimal) + frontend-design (anti-AI-slop craft)
// Direction: editorial, typography-driven, monochrome + 1 accent
// No gradients, no glass cards, no decorative blobs — just hierarchy and whitespace.
const { data } = Astro.props;

const basics = data.basics || {};
const work = data.work || [];
const education = data.education || [];
const skills = data.skills || [];
const languages = data.languages || [];
const interests = data.interests || [];
const meta = data.meta || {};

// Format date range
function fmtDate(d: string | null): string {
  if (!d) return '';
  try {
    const date = new Date(d);
    return date.toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' });
  } catch {
    return d;
  }
}

function formatDateRange(start: string | null, end: string | null): string {
  const s = fmtDate(start);
  const e = end ? fmtDate(end) : "Présent";
  return s ? `${s} — ${e}` : e;
}

// Map skill level to dots
function levelToDots(level: string): number {
  const map: Record<string, number> = {
    'Notions': 1, 'Débutant': 1,
    'Intermédiaire': 2,
    'Avancé': 3,
    'Expert': 4,
  };
  return map[level] || 2;
}

const fullName = basics.name || '';
const nameParts = fullName.split(' ');
const lastName = nameParts.pop() || fullName;
const firstName = nameParts.join(' ') || '';
---

<div class="cv-page">
  <!-- TOOLBAR: screen-only -->
  <div class="toolbar no-print">
    <span class="toolbar-label">CV — {fullName}</span>
    <button onclick="window.print()" class="pdf-btn" aria-label="Télécharger en PDF">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      <span>Télécharger PDF</span>
    </button>
  </div>

  <!-- A4 SHEET -->
  <article class="cv-sheet">

    <!-- HEADER: Name + Title + Contact bar -->
    <header class="cv-header">
      <div class="header-top">
        <h1 class="cv-name">
          <span class="first-name">{firstName}</span>{firstName && ' '}<span class="last-name">{lastName}</span>
        </h1>
        <p class="cv-title">{basics.label}</p>
      </div>

      <!-- Contact: single line, pipe-separated -->
      <nav class="contact-bar" aria-label="Coordonnées">
        {basics.email && <span class="contact-item">{basics.email}</span>}
        {basics.phone && <span class="sep" aria-hidden="true">·</span>}
        {basics.phone && <span class="contact-item">{basics.phone}</span>}
        {basics.location?.city && <span class="sep" aria-hidden="true">·</span>}
        {basics.location?.city && <span class="contact-item">{basics.location.city}, {basics.location.countryCode}</span>}
        {meta.permit && <span class="sep" aria-hidden="true">·</span>}
        {meta.permit && <span class="contact-item permit">{meta.permit}</span>}
      </nav>

      <div class="header-rule"></div>
    </header>

    <!-- SUMMARY -->
    {basics.summary && (
      <section class="cv-summary">
        <p>{basics.summary}</p>
      </section>
    )}

    <!-- TWO COLUMNS: Main (60%) + Aside (40%) -->
    <div class="cv-cols">

      <!-- MAIN COLUMN -->
      <div class="cv-main">

        <!-- EXPERIENCE -->
        <section class="cv-section">
          <h2 class="section-title"><span class="title-mark"></span>Expérience</h2>
          <div class="entries">
            {work.map((job: any) => (
              <article class="entry">
                <div class="entry-head">
                  <h3 class="entry-role">{job.position}</h3>
                  <span class="entry-date">{formatDateRange(job.startDate, job.endDate)}</span>
                </div>
                <p class="entry-org">{job.name}</p>
                {job.highlights && job.highlights.length > 0 && (
                  <ul class="entry-bullets">
                    {job.highlights.map((h: string) => <li>{h}</li>)}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </section>

        <!-- EDUCATION -->
        <section class="cv-section">
          <h2 class="section-title"><span class="title-mark"></span>Formation</h2>
          <div class="entries">
            {education.map((edu: any) => (
              <article class="entry">
                <div class="entry-head">
                  <h3 class="entry-role">{edu.studyType} — {edu.area}</h3>
                  <span class="entry-date">{formatDateRange(edu.startDate, edu.endDate)}</span>
                </div>
                <p class="entry-org">{edu.institution}</p>
                {edu.courses && edu.courses.length > 0 && (
                  <ul class="entry-bullets">
                    {edu.courses.map((c: string) => <li>{c}</li>)}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </section>

        <!-- CERTIFICATES -->
        {meta.certificates && meta.certificates.length > 0 && (
          <section class="cv-section">
            <h2 class="section-title"><span class="title-mark"></span>Certifications</h2>
            <ul class="entry-bullets cert-list">
              {meta.certificates.map((cert: string) => <li>{cert}</li>)}
            </ul>
          </section>
        )}

        <!-- OBJECTIVE -->
        {meta.objective && (
          <section class="cv-section">
            <h2 class="section-title"><span class="title-mark"></span>Objectif</h2>
            <p class="entry-text">{meta.objective}</p>
          </section>
        )}
      </div>

      <!-- ASIDE COLUMN -->
      <aside class="cv-aside">

        <!-- SKILLS -->
        <section class="aside-section">
          <h2 class="aside-title">Compétences</h2>
          <ul class="skill-list">
            {skills.map((skill: any) => {
              const dots = levelToDots(skill.level);
              return (
                <li class="skill-item">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-dots" aria-label={skill.level}>
                    {[1, 2, 3, 4].map((n) => (
                      <span class={`dot ${n <= dots ? 'dot-on' : 'dot-off'}`}></span>
                    ))}
                  </span>
                  <span class="skill-level-print">{skill.level}</span>
                  {skill.keywords?.length > 0 && (
                    <span class="skill-keywords">{skill.keywords.join(', ')}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </section>

        <!-- LANGUAGES -->
        <section class="aside-section">
          <h2 class="aside-title">Langues</h2>
          <ul class="lang-list">
            {languages.map((lang: any) => (
              <li class="lang-item">
                <span class="lang-name">{lang.language}</span>
                <span class="lang-level">{lang.fluency}</span>
              </li>
            ))}
          </ul>
        </section>

        <!-- INTERESTS -->
        <section class="aside-section">
          <h2 class="aside-title">Centres d'intérêt</h2>
          <div class="interest-tags">
            {interests.map((interest: any) => (
              <span class="interest-tag">{interest.name}</span>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </article>
</div>

<!-- ATS structured data -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: basics.name,
  email: basics.email,
  telephone: basics.phone,
  address: { '@type': 'PostalAddress', addressLocality: basics.location?.city, addressCountry: basics.location?.countryCode },
  jobTitle: basics.label,
  description: basics.summary,
  knowsAbout: skills.map((s: any) => s.name),
})} />

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --ink: #1a1a1a;
    --ink-soft: #444;
    --ink-muted: #666;
    --ink-faint: #999;
    --paper: #ffffff;
    --paper-warm: #faf9f7;
    --accent: #1e3a5f;
    --accent-light: #e8edf3;
    --accent-line: #1e3a5f;
    --hairline: #e0ddd8;
    --hairline-soft: #efeae4;
    --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-serif: 'Georgia', 'Cambria', serif;
  }

  /* ===== RESET & BASE ===== */
  .cv-page { font-family: var(--font); color: var(--ink); -webkit-font-smoothing: antialiased; }

  /* ===== TOOLBAR ===== */
  .toolbar {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 24px;
    background: var(--ink); color: #fff;
  }
  .toolbar-label { font-size: 13px; font-weight: 500; opacity: 0.85; }
  .pdf-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 16px; border-radius: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff; font-size: 13px; font-weight: 500;
    cursor: pointer; transition: background 0.15s ease;
  }
  .pdf-btn:hover { background: rgba(255,255,255,0.22); }
  .pdf-btn:active { transform: translateY(1px); }

  /* ===== A4 SHEET ===== */
  .cv-sheet {
    max-width: 210mm; min-height: 297mm; margin: 0 auto;
    background: var(--paper);
    padding: 18mm 16mm;
    box-shadow: 0 2px 40px rgba(0,0,0,0.06);
  }

  /* ===== HEADER ===== */
  .cv-header { margin-bottom: 28px; }
  .header-top { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 4px 0; }
  .cv-name { font-size: 32px; font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 0; }
  .first-name { color: var(--ink); }
  .last-name { color: var(--accent); margin-left: 8px; }
  .cv-title { font-size: 14px; font-weight: 500; color: var(--ink-muted); margin: 4px 0 0; letter-spacing: 0.01em; }

  .contact-bar {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: 0; margin-top: 10px;
    font-size: 12px; color: var(--ink-soft);
  }
  .contact-item { font-weight: 400; }
  .contact-item.permit { color: var(--ink-faint); font-size: 11px; }
  .sep { margin: 0 8px; color: var(--ink-faint); font-weight: 300; }

  .header-rule {
    margin-top: 14px; height: 2px;
    background: var(--ink); border: none;
  }

  /* ===== SUMMARY ===== */
  .cv-summary {
    margin-bottom: 28px; padding: 0;
    font-family: var(--font-serif); font-size: 14px; line-height: 1.65;
    color: var(--ink-soft); font-style: italic;
    max-width: 90%;
  }

  /* ===== TWO COLUMNS ===== */
  .cv-cols {
    display: grid; grid-template-columns: 1fr 0.55fr;
    gap: 36px;
  }

  /* ===== SECTION TITLES (MAIN) ===== */
  .section-title {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--accent);
    margin: 0 0 16px;
  }
  .title-mark {
    display: inline-block; width: 24px; height: 2px;
    background: var(--accent); flex-shrink: 0;
  }

  /* ===== ENTRIES ===== */
  .entries { display: flex; flex-direction: column; gap: 18px; }
  .entry { border-left: none; }
  .entry-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 12px; margin-bottom: 1px;
  }
  .entry-role { font-size: 13.5px; font-weight: 600; color: var(--ink); margin: 0; line-height: 1.3; }
  .entry-date { font-size: 11px; color: var(--ink-faint); white-space: nowrap; font-variant-numeric: tabular-nums; }
  .entry-org { font-size: 12.5px; color: var(--accent); font-weight: 500; margin: 0 0 4px; }
  .entry-text { font-size: 12.5px; color: var(--ink-soft); line-height: 1.55; margin: 0; }

  .entry-bullets {
    list-style: none; padding: 0; margin: 4px 0 0;
    font-size: 12px; color: var(--ink-soft); line-height: 1.55;
  }
  .entry-bullets li {
    position: relative; padding-left: 14px; margin-bottom: 2px;
  }
  .entry-bullets li::before {
    content: ''; position: absolute; left: 0; top: 7px;
    width: 5px; height: 1px; background: var(--accent);
  }
  .cert-list { margin-top: 0; }

  /* ===== MAIN COLUMN SECTIONS ===== */
  .cv-section { margin-bottom: 26px; }
  .cv-section:last-child { margin-bottom: 0; }

  /* ===== ASIDE ===== */
  .cv-aside { display: flex; flex-direction: column; gap: 24px; }
  .aside-section {}
  .aside-title {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--accent);
    margin: 0 0 12px; padding-bottom: 8px;
    border-bottom: 1px solid var(--hairline);
  }

  /* ===== SKILLS ===== */
  .skill-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .skill-item { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 0 8px; }
  .skill-name { font-size: 12px; font-weight: 500; color: var(--ink); }
  .skill-dots { display: inline-flex; gap: 3px; }
  .dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .dot-on { background: var(--accent); }
  .dot-off { background: var(--hairline); }
  .skill-level-print { display: none; font-size: 10px; color: var(--ink-faint); }
  .skill-keywords {
    grid-column: 1 / -1; font-size: 10.5px; color: var(--ink-faint);
    margin-top: 1px; line-height: 1.4;
  }

  /* ===== LANGUAGES ===== */
  .lang-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .lang-item { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; }
  .lang-name { font-size: 12px; font-weight: 500; color: var(--ink); }
  .lang-level { font-size: 10.5px; color: var(--ink-faint); }

  /* ===== INTERESTS ===== */
  .interest-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .interest-tag {
    font-size: 11px; padding: 3px 10px;
    border: 1px solid var(--hairline); border-radius: 3px;
    color: var(--ink-soft); background: var(--paper-warm);
  }

  /* ===== RESPONSIVE ===== */
  @media screen and (max-width: 860px) {
    .cv-cols { grid-template-columns: 1fr; gap: 24px; }
    .cv-sheet { padding: 14mm 10mm; }
    .header-top { flex-direction: column; align-items: flex-start; }
    .cv-name { font-size: 26px; }
  }

  /* ===== PRINT ===== */
  @media print {
    .toolbar, .no-print { display: none !important; }
    .cv-sheet {
      max-width: none; min-height: auto; margin: 0;
      padding: 0; box-shadow: none;
    }
    @page { size: A4; margin: 12mm 14mm; }
    body { font-size: 10.5pt; }
    .cv-summary { max-width: 100%; }
    .skill-dots { display: none; }
    .skill-level-print { display: inline; }
    .cv-cols { gap: 24px; }
    .entry, .aside-section, .cv-section { page-break-inside: avoid; }
    .section-title, .aside-title, h1, h2, h3 { page-break-after: avoid; }
    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
  }
</style>
