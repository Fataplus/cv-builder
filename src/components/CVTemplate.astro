---
// CV Template — Modern Blue (ATS-friendly)
// Semantic HTML structure: header > contact, main > sections
// All text is real HTML text (no JS rendering), ensuring ATS parsers can read it
export interface CVProps {
  data: any;
}

const { data } = Astro.props;

const basics = data.basics || {};
const work = data.work || [];
const education = data.education || [];
const skills = data.skills || [];
const languages = data.languages || [];
const interests = data.interests || [];
const meta = data.meta || {};

// Format date range
function formatDateRange(start: string | null, end: string | null): string {
  const fmt = (d: string | null) => {
    if (!d) return '';
    try {
      const date = new Date(d);
      return date.toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' });
    } catch {
      return d;
    }
  };
  const startStr = fmt(start);
  const endStr = end ? fmt(end) : 'Présent';
  if (startStr && endStr) return `${startStr} — ${endStr}`;
  return endStr;
}

// Map skill level to number of bars (out of 4)
function levelToBars(level: string): number {
  const map: Record<string, number> = {
    'Notions': 1,
    'Débutant': 1,
    'Intermédiaire': 2,
    'Avancé': 3,
    'Expert': 4,
  };
  return map[level] || 2;
}

const fullName = basics.name || '';
const initials = fullName.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 3);
---

<div class="cv-container bg-white shadow-2xl mx-auto" style="max-width: 210mm; min-height: 297mm;">
  <!-- TOOLBAR: Screen-only, hidden in print -->
  <div class="toolbar no-print sticky top-0 z-50 bg-brand-600 text-white px-6 py-3 flex items-center justify-between shadow-md">
    <div class="flex items-center gap-3">
      <span class="text-sm font-medium opacity-90">CV — {fullName}</span>
    </div>
    <div class="flex items-center gap-3">
      <button
        onclick="window.print()"
        class="download-pdf-btn bg-white/15 hover:bg-white/25 transition-colors px-4 py-1.5 rounded-lg text-sm font-medium flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Télécharger PDF
      </button>
    </div>
  </div>

  <!-- ATS-FRIENDLY STRUCTURE: Two-column layout, semantic HTML -->
  <div class="cv-main-grid grid" style="grid-template-columns: 35% 65%;">

    <!-- SIDEBAR: Contact, Skills, Languages, Interests -->
    <aside class="cv-sidebar bg-brand-800 text-white p-6">
      <!-- Avatar / Initials -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-brand-600 text-3xl font-bold ring-4 ring-brand-400/30">
          {initials}
        </div>
      </div>

      <!-- CONTACT — ATS reads this section for phone/email/location -->
      <section class="mb-6">
        <h2 class="text-xs uppercase tracking-wider font-bold text-brand-300 mb-3 border-b border-brand-600 pb-2">
          Contact
        </h2>
        <ul class="space-y-2 text-sm">
          {basics.phone && (
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 text-brand-300"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>{basics.phone}</span>
            </li>
          )}
          {basics.email && (
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 text-brand-300"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span class="break-all">{basics.email}</span>
            </li>
          )}
          {basics.location && (
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 text-brand-300"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{[basics.location.city, basics.location.countryCode].filter(Boolean).join(', ')}</span>
            </li>
          )}
        </ul>
        {meta.permit && (
          <p class="mt-2 text-xs text-brand-300">{meta.permit}</p>
        )}
      </section>

      <!-- SKILLS — ATS keyword extraction section -->
      <section class="mb-6">
        <h2 class="text-xs uppercase tracking-wider font-bold text-brand-300 mb-3 border-b border-brand-600 pb-2">
          Compétences
        </h2>
        <ul class="space-y-2.5">
          {skills.map((skill: any) => {
            const bars = levelToBars(skill.level);
            return (
              <li>
                <p class="text-sm font-medium">{skill.name}</p>
                <!-- ATS: skill level as text (hidden on screen, visible in print) -->
                <span class="skill-level-text text-xs text-brand-300">{skill.level}</span>
                <div class="skill-bar flex gap-1 mt-1">
                  {[1, 2, 3, 4].map((n) => (
                    <div class={`h-1.5 flex-1 rounded-full ${n <= bars ? 'bg-brand-400' : 'bg-brand-600/40'}`}></div>
                  ))}
                </div>
                {skill.keywords && skill.keywords.length > 0 && (
                  <p class="text-xs text-brand-300 mt-0.5">{skill.keywords.join(', ')}</p>
                )}
              </li>
            );
          })}
        </ul>
      </section>

      <!-- LANGUAGES -->
      <section class="mb-6">
        <h2 class="text-xs uppercase tracking-wider font-bold text-brand-300 mb-3 border-b border-brand-600 pb-2">
          Langues
        </h2>
        <ul class="space-y-1.5 text-sm">
          {languages.map((lang: any) => (
            <li class="flex justify-between">
              <span>{lang.language}</span>
              <span class="text-brand-300 text-xs">{lang.fluency}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- INTERESTS -->
      <section>
        <h2 class="text-xs uppercase tracking-wider font-bold text-brand-300 mb-3 border-b border-brand-600 pb-2">
          Centres d'intérêt
        </h2>
        <div class="flex flex-wrap gap-2">
          {interests.map((interest: any) => (
            <span class="text-xs bg-brand-700/60 px-2.5 py-1 rounded-full">{interest.name}</span>
          ))}
        </div>
      </section>
    </aside>

    <!-- MAIN: Profile, Experience, Education -->
    <main class="cv-main bg-white p-6">
      <!-- HEADER: Name + Title — ATS key fields -->
      <header class="mb-6 pb-4 border-b-2 border-brand-100">
        <h1 class="text-3xl font-bold text-brand-900 tracking-tight">{fullName}</h1>
        <p class="text-lg text-brand-600 font-medium mt-1">{basics.label}</p>
      </header>

      <!-- SUMMARY / OBJECTIVE -->
      {basics.summary && (
        <section class="cv-section mb-6">
          <h2 class="text-sm uppercase tracking-wider font-bold text-brand-700 mb-2">
            Profil
          </h2>
          <p class="text-sm text-gray-700 leading-relaxed">{basics.summary}</p>
        </section>
      )}

      {meta.objective && (
        <section class="cv-section mb-6">
          <h2 class="text-sm uppercase tracking-wider font-bold text-brand-700 mb-2">
            Objectif professionnel
          </h2>
          <p class="text-sm text-gray-700 leading-relaxed">{meta.objective}</p>
        </section>
      )}

      <!-- EXPERIENCE — ATS core parsing section -->
      <section class="cv-section mb-6">
        <h2 class="text-sm uppercase tracking-wider font-bold text-brand-700 mb-3">
          Expérience professionnelle
        </h2>
        <div class="space-y-4">
          {work.map((job: any) => (
            <article class="experience-item">
              <div class="flex justify-between items-baseline mb-0.5">
                <h3 class="text-sm font-bold text-gray-900">{job.position}</h3>
                <span class="text-xs text-gray-500 whitespace-nowrap">
                  {formatDateRange(job.startDate, job.endDate)}
                </span>
              </div>
              <p class="text-sm text-brand-600 font-medium mb-1">{job.name}</p>
              {job.summary && (
                <p class="text-xs text-gray-600 mb-1.5">{job.summary}</p>
              )}
              {job.highlights && job.highlights.length > 0 && (
                <ul class="text-xs text-gray-700 space-y-0.5 ml-4 list-disc">
                  {job.highlights.map((h: string) => (
                    <li>{h}</li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </div>
      </section>

      <!-- EDUCATION -->
      <section class="cv-section mb-6">
        <h2 class="text-sm uppercase tracking-wider font-bold text-brand-700 mb-3">
          Formation
        </h2>
        <div class="space-y-4">
          {education.map((edu: any) => (
            <article class="education-item">
              <div class="flex justify-between items-baseline mb-0.5">
                <h3 class="text-sm font-bold text-gray-900">{edu.studyType}</h3>
                <span class="text-xs text-gray-500 whitespace-nowrap">
                  {formatDateRange(edu.startDate, edu.endDate)}
                </span>
              </div>
              <p class="text-sm text-brand-600 font-medium mb-0.5">{edu.institution}</p>
              <p class="text-xs text-gray-600">{edu.area}</p>
              {edu.score && (
                <p class="text-xs text-gray-500 mt-0.5">{edu.score}</p>
              )}
              {edu.courses && edu.courses.length > 0 && (
                <ul class="text-xs text-gray-700 space-y-0.5 ml-4 list-disc mt-1">
                  {edu.courses.map((c: string) => (
                    <li>{c}</li>
                  ))}
                </ul>
              )}
            </article>
          ))}
        </div>
      </section>

      <!-- CERTIFICATES -->
      {meta.certificates && meta.certificates.length > 0 && (
        <section class="cv-section">
          <h2 class="text-sm uppercase tracking-wider font-bold text-brand-700 mb-3">
            Certifications
          </h2>
          <ul class="text-xs text-gray-700 space-y-1 ml-4 list-disc">
            {meta.certificates.map((cert: string) => (
              <li>{cert}</li>
            ))}
          </ul>
        </section>
      )}
    </main>
  </div>
</div>

<!-- Hidden ATS data block — structured data for parsers that look for JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: basics.name,
  email: basics.email,
  telephone: basics.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: basics.location?.city,
    addressCountry: basics.location?.countryCode,
  },
  jobTitle: basics.label,
  description: basics.summary,
  knowsAbout: skills.map((s: any) => s.name),
})} />
